end)

SkinCreator_V1.Yin___Yang.MouseButton1Up:Connect(function()
	EquippedSkin.Value = "Darkness"
end)

SkinCreator_V1.Dupe_XP.MouseButton1Up:Connect(function()
	local XP = game:GetService("Players").LocalPlayer.leaderstats.XP.Value

	local Event = game:GetService("ReplicatedStorage").GiveXP
	Event:FireServer(
    	XP
	)
end)

SkinCreator_V1.Dupe_Volts.MouseButton1Up:Connect(function()
	local Volts = game:GetService("Players").LocalPlayer.Volts.Value

	local Event2 = game:GetService("ReplicatedStorage").GiveVolts
	Event2:FireServer(
    	Volts,
    	"click"
	)
end)

